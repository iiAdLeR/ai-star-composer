NASA_API_KEY=your_key_optional_for_future_apis

# Optional: professional audio (FluidSynth + SoundFont)
# Download a GM SoundFont (e.g. FluidR3 GM) and set full path:
# SOUNDFONT_PATH=C:/audio/FluidR3_GM.sf2
SOUNDFONT_PATH=
# If fluidsynth is not on PATH, set full path to the executable:
# FLUIDSYNTH_BIN=C:/tools/fluidsynth/bin/fluidsynth.exe
FLUIDSYNTH_BIN=fluidsynth

DATA_DIR=data
OUTPUTS_DIR=outputs

# Optional: trained sequence LSTM (.pt) — blends melody in /generate, /compare, live when use_lstm=true
# LSTM_CHECKPOINT_PATH=C:/path/to/checkpoint.pt
LSTM_CHECKPOINT_PATH=
